<UserControl x:Class="Dyncamelo.UI.Views.DyncameloEditorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:nodify="https://miroiu.github.io/nodify"
             xmlns:vm="clr-namespace:Dyncamelo.UI.ViewModels"
             MinWidth="400"
             MinHeight="300">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Dyncamelo.UI;component/Themes/DyncameloDark.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <UserControl.InputBindings>
        <KeyBinding Key="N" Modifiers="Control" Command="{Binding NewCommand}" />
        <KeyBinding Key="O" Modifiers="Control" Command="{Binding OpenCommand}" />
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveCommand}" />
        <KeyBinding Key="S" Modifiers="Control+Shift" Command="{Binding SaveAsCommand}" />
        <KeyBinding Key="F2" Command="{Binding RenameCommand}" />
        <KeyBinding Key="D" Modifiers="Control" Command="{Binding DuplicateSelectionCommand}" />
        <KeyBinding Key="C" Modifiers="Control" Command="{Binding CopySelectionCommand}" />
        <KeyBinding Key="V" Modifiers="Control" Command="{Binding PasteCommand}" />
        <KeyBinding Key="G" Modifiers="Control" Command="{Binding GroupSelectionCommand}" />
        <KeyBinding Key="F5" Command="{Binding RunCommand}" />
    </UserControl.InputBindings>

    <DockPanel Background="{StaticResource Dyc.PanelBrush}">

        <!-- ===== Brand bar (BIMCamel identity) — the blue gradient header carries
             the logo in a black chip so its baked-in black background reads as an
             intentional rounded badge, matching the BIMCamel exporter's title bar. -->
        <Border DockPanel.Dock="Top" Height="38" Background="{StaticResource Dyc.BrandBrush}">
            <Grid Margin="10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0"
                        Width="26" Height="26"
                        CornerRadius="7"
                        Background="{StaticResource Dyc.LogoChipBrush}"
                        VerticalAlignment="Center">
                    <Image Source="pack://application:,,,/Dyncamelo.UI;component/Assets/camel_32.png"
                           Width="22" Height="22"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="9,0,0,0">
                    <TextBlock Text="Dyncamelo"
                               Foreground="{StaticResource Dyc.OnBrandBrush}"
                               FontWeight="SemiBold"
                               FontSize="13.5" />
                    <TextBlock Text="by BIMCamel"
                               Foreground="{StaticResource Dyc.OnBrandSubtleBrush}"
                               FontSize="9.5"
                               Margin="0,-1,0,0" />
                </StackPanel>
                <TextBlock Grid.Column="2"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource Dyc.OnBrandSubtleBrush}"
                           FontSize="11"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="260"
                           Text="{Binding Title}" />
            </Grid>
        </Border>

        <!-- ===== Toolbar ===== -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource Dyc.PanelBrush}"
                BorderBrush="{StaticResource Dyc.PanelBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="4,3">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Style="{StaticResource Dyc.ToolButton}" ToolTip="New graph (Ctrl+N)" Command="{Binding NewCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource Dyc.ToolIcon}" Data="{StaticResource Dyc.Icon.New}" />
                            <TextBlock Text="New" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource Dyc.ToolButton}" ToolTip="Open .dyc graph (Ctrl+O)" Command="{Binding OpenCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource Dyc.ToolIcon}" Data="{StaticResource Dyc.Icon.Open}" />
                            <TextBlock Text="Open" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="OpenRecentButton"
                            Style="{StaticResource Dyc.ToolButton}"
                            Content="▾"
                            Padding="4,4"
                            Margin="0,0,1,0"
                            ToolTip="Open a recent graph or a sample"
                            Click="OnOpenRecentClick"
                            ContextMenuOpening="OnOpenRecentContextMenuOpening">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <ContextMenu.Resources>
                                    <!-- Submenus disable themselves while empty. -->
                                    <Style x:Key="Dyc.EmptyDisabledSubmenu" TargetType="{x:Type MenuItem}" BasedOn="{StaticResource Dyc.MenuItem}">
                                        <Style.Triggers>
                                            <Trigger Property="HasItems" Value="False">
                                                <Setter Property="IsEnabled" Value="False" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ContextMenu.Resources>
                                <MenuItem Header="Recent Files"
                                          Style="{StaticResource Dyc.EmptyDisabledSubmenu}"
                                          ItemsSource="{Binding RecentFiles}">
                                    <MenuItem.ItemContainerStyle>
                                        <Style TargetType="{x:Type MenuItem}" BasedOn="{StaticResource Dyc.MenuItem}">
                                            <Setter Property="Header" Value="{Binding}" />
                                            <Setter Property="Command" Value="{Binding PlacementTarget.DataContext.OpenRecentFileCommand, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" />
                                            <Setter Property="CommandParameter" Value="{Binding}" />
                                            <!-- Render the raw path: a plain Header would eat underscores as access keys. -->
                                            <Setter Property="HeaderTemplate">
                                                <Setter.Value>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding}" MaxWidth="480" TextTrimming="CharacterEllipsis" />
                                                    </DataTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </MenuItem.ItemContainerStyle>
                                </MenuItem>
                                <MenuItem Header="Sample Graphs"
                                          Style="{StaticResource Dyc.EmptyDisabledSubmenu}"
                                          ItemsSource="{Binding SampleGraphs}">
                                    <MenuItem.ItemContainerStyle>
                                        <Style TargetType="{x:Type MenuItem}" BasedOn="{StaticResource Dyc.MenuItem}">
                                            <Setter Property="Header" Value="{Binding Name}" />
                                            <Setter Property="ToolTip" Value="{Binding FilePath}" />
                                            <!-- Each item carries its own open command (no ancestor lookup needed). -->
                                            <Setter Property="Command" Value="{Binding OpenCommand}" />
                                            <Setter Property="CommandParameter" Value="{Binding}" />
                                            <!-- Render the raw name: a plain Header would eat underscores as access keys. -->
                                            <Setter Property="HeaderTemplate">
                                                <Setter.Value>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding}" MaxWidth="360" TextTrimming="CharacterEllipsis" />
                                                    </DataTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </MenuItem.ItemContainerStyle>
                                </MenuItem>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Button Style="{StaticResource Dyc.ToolButton}" ToolTip="Save graph (Ctrl+S)" Command="{Binding SaveCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource Dyc.ToolIcon}" Data="{StaticResource Dyc.Icon.Save}" />
                            <TextBlock Text="Save" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource Dyc.ToolButton}" ToolTip="Save graph to a new file (Ctrl+Shift+S)" Command="{Binding SaveAsCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource Dyc.ToolIcon}" Data="{StaticResource Dyc.Icon.SaveAs}" />
                            <TextBlock Text="Save As" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource Dyc.ToolButton}" ToolTip="Rename the current .dyc file (F2)" Command="{Binding RenameCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource Dyc.ToolIcon}" Data="{StaticResource Dyc.Icon.Rename}" />
                            <TextBlock Text="Rename" />
                        </StackPanel>
                    </Button>

                    <Border Width="1" Margin="6,2" Background="{StaticResource Dyc.PanelBorderBrush}" />

                    <Button Style="{StaticResource Dyc.ToolButton}" ToolTip="Run the graph (F5)" Command="{Binding RunCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource Dyc.ToolIcon}" Data="{StaticResource Dyc.Icon.Run}" Fill="{StaticResource Dyc.AccentBrush}" />
                            <TextBlock Text="Run" />
                        </StackPanel>
                    </Button>
                    <ToggleButton Style="{StaticResource Dyc.ToolToggle}"
                                  ToolTip="Re-run automatically after every change"
                                  IsChecked="{Binding IsAutoRun}">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource Dyc.ToolIcon}" Data="{StaticResource Dyc.Icon.Auto}" />
                            <TextBlock Text="Auto" />
                        </StackPanel>
                    </ToggleButton>
                    <ToggleButton Style="{StaticResource Dyc.ToolToggle}"
                                  ToolTip="Show a value preview bubble under each node after a run"
                                  IsChecked="{Binding ShowNodePreviews}">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource Dyc.ToolIcon}" Data="{StaticResource Dyc.Icon.Preview}" />
                            <TextBlock Text="Preview" />
                        </StackPanel>
                    </ToggleButton>

                    <Border Width="1" Margin="6,2" Background="{StaticResource Dyc.PanelBorderBrush}" />

                    <Button Style="{StaticResource Dyc.ToolButton}"
                            ToolTip="Zoom to fit all nodes"
                            Command="{x:Static nodify:EditorCommands.FitToScreen}"
                            CommandTarget="{Binding ElementName=Editor}">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource Dyc.ToolIcon}" Data="{StaticResource Dyc.Icon.Fit}" />
                            <TextBlock Text="Fit" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource Dyc.ToolButton}"
                            Content="+"
                            ToolTip="Zoom in"
                            Command="{x:Static nodify:EditorCommands.ZoomIn}"
                            CommandTarget="{Binding ElementName=Editor}" />
                    <Button Style="{StaticResource Dyc.ToolButton}"
                            Content="−"
                            ToolTip="Zoom out"
                            Command="{x:Static nodify:EditorCommands.ZoomOut}"
                            CommandTarget="{Binding ElementName=Editor}" />

                    <Border Width="1" Margin="6,2" Background="{StaticResource Dyc.PanelBorderBrush}" />

                    <Button Style="{StaticResource Dyc.ToolButton}"
                            ToolTip="Add a note at the center of the view"
                            Click="OnAddNoteClick">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource Dyc.ToolIcon}" Data="{StaticResource Dyc.Icon.Note}" />
                            <TextBlock Text="Note" />
                        </StackPanel>
                    </Button>

                    <Border Width="1" Margin="6,2" Background="{StaticResource Dyc.PanelBorderBrush}" />

                    <!-- ===== Settings (descriptions / double-click action / colour palette) ===== -->
                    <ToggleButton x:Name="SettingsButton"
                                  Style="{StaticResource Dyc.ToolToggle}"
                                  ToolTip="Settings">
                        <Path Style="{StaticResource Dyc.ToolIcon}" Margin="0" Data="{StaticResource Dyc.Icon.Settings}" />
                    </ToggleButton>
                    <Popup PlacementTarget="{Binding ElementName=SettingsButton}"
                           Placement="Bottom"
                           StaysOpen="False"
                           AllowsTransparency="True"
                           PopupAnimation="Fade"
                           IsOpen="{Binding IsChecked, ElementName=SettingsButton, Mode=TwoWay}">
                        <!-- No DropShadowEffect: a bordered, rounded popup reads fine and
                             avoids the render-to-bitmap pass that shadows force in WPF. -->
                        <Border Background="{StaticResource Dyc.PanelBrush}"
                                BorderBrush="{StaticResource Dyc.PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Margin="6"
                                Padding="14">
                            <StackPanel Width="230">
                                <TextBlock Text="Settings"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource Dyc.TextBrush}"
                                           Margin="0,0,0,10" />

                                <ToggleButton Style="{StaticResource Dyc.SmallToggle}"
                                              HorizontalAlignment="Left"
                                              Content="Show node descriptions"
                                              ToolTip="Show a description line under each library node"
                                              IsChecked="{Binding Library.ShowDescriptions}" />

                                <ToggleButton Style="{StaticResource Dyc.SmallToggle}"
                                              HorizontalAlignment="Left"
                                              Margin="0,8,0,0"
                                              Content="Highlight selected node in Navisworks"
                                              ToolTip="Select the model items a node outputs in the Navisworks viewport when you click the node. Overwrites the live selection, so turn off if you use Selection.Current."
                                              IsChecked="{Binding PreviewSelection}" />

                                <TextBlock Text="Double-click empty canvas"
                                           Foreground="{StaticResource Dyc.SubtleTextBrush}"
                                           Margin="0,14,0,4" />
                                <ItemsControl ItemsSource="{Binding DoubleClickActions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <!-- ElementName (not FindAncestor): the Popup is a separate
                                                 visual tree, so an AncestorType=UserControl walk never
                                                 reaches the view model. SettingsButton shares this
                                                 namescope and its DataContext is the view model. -->
                                            <Button Style="{StaticResource Dyc.SettingsChoice}"
                                                    Content="{Binding DisplayName}"
                                                    Command="{Binding DataContext.SelectDoubleClickActionCommand, ElementName=SettingsButton}"
                                                    CommandParameter="{Binding}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="Colour palette"
                                           Foreground="{StaticResource Dyc.SubtleTextBrush}"
                                           Margin="0,14,0,4" />
                                <ItemsControl ItemsSource="{Binding Palettes}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource Dyc.SettingsChoice}"
                                                    Command="{Binding DataContext.SelectPaletteCommand, ElementName=SettingsButton}"
                                                    CommandParameter="{Binding}">
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Width="12" Height="12" CornerRadius="2" Margin="0,0,8,0"
                                                            Background="{Binding Swatch}"
                                                            BorderBrush="{StaticResource Dyc.PanelBorderBrush}"
                                                            BorderThickness="1" />
                                                    <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </Popup>
                </StackPanel>

                <Border />
            </DockPanel>
        </Border>

        <!-- ===== Status bar ===== -->
        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource Dyc.PanelBrush}"
                BorderBrush="{StaticResource Dyc.PanelBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="8,3">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <TextBlock Foreground="{StaticResource Dyc.SubtleTextBrush}" Text="Nodes: " />
                    <TextBlock Foreground="{StaticResource Dyc.TextBrush}" Text="{Binding NodeCount}" />
                    <TextBlock Foreground="{StaticResource Dyc.SubtleTextBrush}" Text="   Warnings: " />
                    <TextBlock Foreground="{StaticResource Dyc.WarningBrush}" Text="{Binding WarningCount}" />
                    <TextBlock Foreground="{StaticResource Dyc.SubtleTextBrush}" Text="   Errors: " />
                    <TextBlock Foreground="{StaticResource Dyc.ErrorBrush}" Text="{Binding ErrorCount}" />
                    <TextBlock Foreground="{StaticResource Dyc.SubtleTextBrush}" Text="   Last run: " />
                    <TextBlock Foreground="{StaticResource Dyc.TextBrush}" Text="{Binding LastRunMilliseconds}" />
                    <TextBlock Foreground="{StaticResource Dyc.SubtleTextBrush}" Text=" ms" />
                </StackPanel>
                <TextBlock Foreground="{StaticResource Dyc.SubtleTextBrush}"
                           TextTrimming="CharacterEllipsis"
                           Text="{Binding StatusMessage}" />
            </DockPanel>
        </Border>

        <!-- ===== Library + canvas ===== -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230" MinWidth="150" />
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Library browser -->
            <DockPanel x:Name="LibraryPanel"
                       Grid.Column="0"
                       Background="{StaticResource Dyc.PanelBrush}"
                       PreviewKeyDown="OnLibraryPanelPreviewKeyDown"
                       IsKeyboardFocusWithinChanged="OnLibraryPanelIsKeyboardFocusWithinChanged">
                <DockPanel.Resources>
                    <!-- One entry row template shared by the category tree and the
                         flat search results (implicit by DataType). -->
                    <DataTemplate DataType="{x:Type vm:LibraryEntryViewModel}">
                        <Grid x:Name="EntryRow"
                              Background="Transparent"
                              ToolTipService.ShowDuration="30000"
                              ToolTipService.InitialShowDelay="200">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.ToolTip>
                                <ToolTip MaxWidth="380">
                                    <StackPanel Margin="2">
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding Category}" Opacity="0.7" Margin="0,1,0,0" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding Description}"
                                                   Margin="0,6,0,0"
                                                   TextWrapping="Wrap"
                                                   Visibility="{Binding HasDescription, Converter={StaticResource Dyc.BoolToVisibility}}" />
                                        <TextBlock Text="{Binding Signature}"
                                                   Margin="0,6,0,0"
                                                   FontStyle="Italic"
                                                   Opacity="0.85"
                                                   TextWrapping="Wrap"
                                                   Visibility="{Binding HasSignature, Converter={StaticResource Dyc.BoolToVisibility}}" />
                                    </StackPanel>
                                </ToolTip>
                            </Grid.ToolTip>
                            <StackPanel Margin="0,1">
                                <TextBlock Text="{Binding Name}"
                                           Foreground="{StaticResource Dyc.TextBrush}"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding Description}"
                                           FontSize="11"
                                           Foreground="{StaticResource Dyc.SubtleTextBrush}"
                                           TextWrapping="Wrap"
                                           TextTrimming="CharacterEllipsis"
                                           MaxHeight="30"
                                           Margin="0,1,0,0"
                                           Visibility="{Binding IsDescriptionVisible, Converter={StaticResource Dyc.BoolToVisibility}}" />
                            </StackPanel>
                            <Button x:Name="StarButton"
                                    Grid.Column="1"
                                    VerticalAlignment="Top"
                                    Margin="6,1,2,0"
                                    Padding="2,0"
                                    Content="☆"
                                    FontSize="13"
                                    Cursor="Hand"
                                    Visibility="Hidden"
                                    Foreground="{StaticResource Dyc.SubtleTextBrush}"
                                    ToolTip="Add to favourites"
                                    Command="{Binding DataContext.Library.ToggleFavoriteCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                    CommandParameter="{Binding}">
                                <Button.Template>
                                    <ControlTemplate TargetType="{x:Type Button}">
                                        <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                        <DataTemplate.Triggers>
                            <Trigger SourceName="EntryRow" Property="IsMouseOver" Value="True">
                                <Setter TargetName="StarButton" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                <Setter TargetName="StarButton" Property="Visibility" Value="Visible" />
                                <Setter TargetName="StarButton" Property="Content" Value="★" />
                                <Setter TargetName="StarButton" Property="Foreground" Value="{StaticResource Dyc.WarningBrush}" />
                                <Setter TargetName="StarButton" Property="ToolTip" Value="Remove from favourites" />
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </DockPanel.Resources>
                <!-- Search row: a search-icon field with an inline quick-clear ✕, and
                     compact expand/collapse symbol buttons sitting right beside it.
                     (The "show descriptions" toggle now lives in the Settings popup.) -->
                <DockPanel DockPanel.Dock="Top" Margin="6,6,6,4">
                    <Button DockPanel.Dock="Right"
                            Style="{StaticResource Dyc.IconButton}"
                            Margin="4,0,0,0"
                            ToolTip="Collapse all categories"
                            Command="{Binding Library.CollapseAllCommand}">
                        <Path Width="14" Height="14" Stretch="Uniform"
                              Fill="{StaticResource Dyc.SubtleTextBrush}"
                              Data="{StaticResource Dyc.Icon.UnfoldLess}" />
                    </Button>
                    <Button DockPanel.Dock="Right"
                            Style="{StaticResource Dyc.IconButton}"
                            Margin="4,0,0,0"
                            ToolTip="Expand all categories"
                            Command="{Binding Library.ExpandAllCommand}">
                        <Path Width="14" Height="14" Stretch="Uniform"
                              Fill="{StaticResource Dyc.SubtleTextBrush}"
                              Data="{StaticResource Dyc.Icon.UnfoldMore}" />
                    </Button>
                    <Grid>
                        <TextBox FontSize="13"
                                 Style="{StaticResource Dyc.TextBox}"
                                 Padding="26,3,22,3"
                                 Text="{Binding Library.SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Search nodes (Esc clears)" />
                        <!-- Search glyph inside the field (transparent to clicks). -->
                        <Path Width="14" Height="14" Stretch="Uniform"
                              HorizontalAlignment="Left" VerticalAlignment="Center"
                              Margin="7,0,0,0"
                              IsHitTestVisible="False"
                              Fill="{StaticResource Dyc.SubtleTextBrush}"
                              Data="{StaticResource Dyc.Icon.Search}" />
                        <Button HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="0,0,4,0"
                                Padding="3,0"
                                Content="✕"
                                FontSize="11"
                                Cursor="Hand"
                                Foreground="{StaticResource Dyc.SubtleTextBrush}"
                                ToolTip="Clear search"
                                Command="{Binding Library.ClearSearchCommand}"
                                Visibility="{Binding Library.HasSearchText, Converter={StaticResource Dyc.BoolToVisibility}}">
                            <Button.Template>
                                <ControlTemplate TargetType="{x:Type Button}">
                                    <Border x:Name="Chrome" Background="Transparent" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Chrome" Property="Background" Value="{StaticResource Dyc.HoverBrush}" />
                                            <Setter Property="Foreground" Value="{StaticResource Dyc.TextBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </DockPanel>
                <Grid>
                    <TreeView x:Name="LibraryTree"
                              Margin="2,0,2,2"
                              Background="Transparent"
                              BorderThickness="0"
                              FontSize="13"
                              Foreground="{StaticResource Dyc.TextBrush}"
                              ItemsSource="{Binding Library.RootItems}"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              PreviewMouseLeftButtonDown="OnLibraryMouseDown"
                              PreviewMouseMove="OnLibraryMouseMove"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <TreeView.Style>
                            <Style TargetType="{x:Type TreeView}">
                                <Style.Triggers>
                                    <!-- While searching, the flat result list replaces the
                                         tree; the tree keeps its expansion state untouched. -->
                                    <DataTrigger Binding="{Binding Library.IsSearching}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TreeView.Style>
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="{x:Type TreeViewItem}">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                                <Setter Property="Foreground" Value="{StaticResource Dyc.TextBrush}" />
                                <Setter Property="Padding" Value="0,2" />
                                <EventSetter Event="MouseDoubleClick" Handler="OnLibraryItemDoubleClick" />
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.Resources>
                            <!-- Selection colors for the default TreeViewItem template. Their
                                 Color is bound to the theme brushes so the selection highlight
                                 follows a live palette swap (the palette mutates those brushes'
                                 Color in place). -->
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="{Binding Color, Source={StaticResource Dyc.HoverBrush}}" />
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="{Binding Color, Source={StaticResource Dyc.TextBrush}}" />
                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="{Binding Color, Source={StaticResource Dyc.PanelBorderBrush}}" />
                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="{Binding Color, Source={StaticResource Dyc.TextBrush}}" />
                            <HierarchicalDataTemplate DataType="{x:Type vm:LibraryCategoryViewModel}" ItemsSource="{Binding Children}">
                                <!-- A per-root Material glyph (IconKey, top-level categories only) precedes the name. -->
                                <StackPanel Orientation="Horizontal" Margin="0,2">
                                    <Path x:Name="CategoryIcon"
                                          Width="13" Height="13"
                                          Stretch="Uniform"
                                          VerticalAlignment="Center"
                                          Margin="0,0,6,0"
                                          Fill="{StaticResource Dyc.SubtleTextBrush}"
                                          Visibility="Collapsed" />
                                    <TextBlock x:Name="CategoryText"
                                               Text="{Binding Name}"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource Dyc.SubtleTextBrush}" />
                                </StackPanel>
                                <HierarchicalDataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IconKey}" Value="Annotation">
                                        <Setter TargetName="CategoryIcon" Property="Data" Value="{StaticResource Dyc.Icon.Cat.Annotation}" />
                                        <Setter TargetName="CategoryIcon" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IconKey}" Value="Color">
                                        <Setter TargetName="CategoryIcon" Property="Data" Value="{StaticResource Dyc.Icon.Cat.Color}" />
                                        <Setter TargetName="CategoryIcon" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IconKey}" Value="DateTime">
                                        <Setter TargetName="CategoryIcon" Property="Data" Value="{StaticResource Dyc.Icon.Cat.DateTime}" />
                                        <Setter TargetName="CategoryIcon" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IconKey}" Value="Dictionary">
                                        <Setter TargetName="CategoryIcon" Property="Data" Value="{StaticResource Dyc.Icon.Cat.Dictionary}" />
                                        <Setter TargetName="CategoryIcon" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IconKey}" Value="Display">
                                        <Setter TargetName="CategoryIcon" Property="Data" Value="{StaticResource Dyc.Icon.Cat.Display}" />
                                        <Setter TargetName="CategoryIcon" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IconKey}" Value="File">
                                        <Setter TargetName="CategoryIcon" Property="Data" Value="{StaticResource Dyc.Icon.Cat.File}" />
                                        <Setter TargetName="CategoryIcon" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IconKey}" Value="Geometry">
                                        <Setter TargetName="CategoryIcon" Property="Data" Value="{StaticResource Dyc.Icon.Cat.Geometry}" />
                                        <Setter TargetName="CategoryIcon" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IconKey}" Value="Input">
                                        <Setter TargetName="CategoryIcon" Property="Data" Value="{StaticResource Dyc.Icon.Cat.Input}" />
                                        <Setter TargetName="CategoryIcon" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IconKey}" Value="List">
                                        <Setter TargetName="CategoryIcon" Property="Data" Value="{StaticResource Dyc.Icon.Cat.List}" />
                                        <Setter TargetName="CategoryIcon" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IconKey}" Value="Logic">
                                        <Setter TargetName="CategoryIcon" Property="Data" Value="{StaticResource Dyc.Icon.Cat.Logic}" />
                                        <Setter TargetName="CategoryIcon" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IconKey}" Value="Math">
                                        <Setter TargetName="CategoryIcon" Property="Data" Value="{StaticResource Dyc.Icon.Cat.Math}" />
                                        <Setter TargetName="CategoryIcon" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IconKey}" Value="Navisworks">
                                        <Setter TargetName="CategoryIcon" Property="Data" Value="{StaticResource Dyc.Icon.Cat.Navisworks}" />
                                        <Setter TargetName="CategoryIcon" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IconKey}" Value="String">
                                        <Setter TargetName="CategoryIcon" Property="Data" Value="{StaticResource Dyc.Icon.Cat.String}" />
                                        <Setter TargetName="CategoryIcon" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IconKey}" Value="Workflow">
                                        <Setter TargetName="CategoryIcon" Property="Data" Value="{StaticResource Dyc.Icon.Cat.Workflow}" />
                                        <Setter TargetName="CategoryIcon" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IconKey}" Value="Table">
                                        <Setter TargetName="CategoryIcon" Property="Data" Value="{StaticResource Dyc.Icon.Cat.Table}" />
                                        <Setter TargetName="CategoryIcon" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IconKey}" Value="Favorites">
                                        <Setter TargetName="CategoryIcon" Property="Data" Value="{StaticResource Dyc.Icon.Cat.Favorites}" />
                                        <Setter TargetName="CategoryIcon" Property="Fill" Value="{StaticResource Dyc.WarningBrush}" />
                                        <Setter TargetName="CategoryIcon" Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Name}" Value="★ Favourites">
                                        <Setter TargetName="CategoryText" Property="Foreground" Value="{StaticResource Dyc.WarningBrush}" />
                                    </DataTrigger>
                                    <!-- Create / Modify / Info leaf-grouping headers: coloured glyph + label. -->
                                    <DataTrigger Binding="{Binding IconKey}" Value="FnCreate">
                                        <Setter TargetName="CategoryIcon" Property="Data" Value="{StaticResource Dyc.Icon.FnCreate}" />
                                        <Setter TargetName="CategoryIcon" Property="Fill" Value="{StaticResource Dyc.FnCreateBrush}" />
                                        <Setter TargetName="CategoryIcon" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="CategoryText" Property="Foreground" Value="{StaticResource Dyc.FnCreateBrush}" />
                                        <Setter TargetName="CategoryText" Property="FontSize" Value="11" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IconKey}" Value="FnModify">
                                        <Setter TargetName="CategoryIcon" Property="Data" Value="{StaticResource Dyc.Icon.FnModify}" />
                                        <Setter TargetName="CategoryIcon" Property="Fill" Value="{StaticResource Dyc.FnModifyBrush}" />
                                        <Setter TargetName="CategoryIcon" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="CategoryText" Property="Foreground" Value="{StaticResource Dyc.FnModifyBrush}" />
                                        <Setter TargetName="CategoryText" Property="FontSize" Value="11" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IconKey}" Value="FnInfo">
                                        <Setter TargetName="CategoryIcon" Property="Data" Value="{StaticResource Dyc.Icon.FnInfo}" />
                                        <Setter TargetName="CategoryIcon" Property="Fill" Value="{StaticResource Dyc.FnInfoBrush}" />
                                        <Setter TargetName="CategoryIcon" Property="Visibility" Value="Visible" />
                                        <Setter TargetName="CategoryText" Property="Foreground" Value="{StaticResource Dyc.FnInfoBrush}" />
                                        <Setter TargetName="CategoryText" Property="FontSize" Value="11" />
                                    </DataTrigger>
                                </HierarchicalDataTemplate.Triggers>
                            </HierarchicalDataTemplate>
                        </TreeView.Resources>
                    </TreeView>
                    <!-- Flat search results (Dynamo-style) -->
                    <DockPanel Visibility="{Binding Library.IsSearching, Converter={StaticResource Dyc.BoolToVisibility}}">
                        <TextBlock DockPanel.Dock="Bottom"
                                   Margin="8,4"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource Dyc.SubtleTextBrush}"
                                   Text="{Binding Library.SearchStatusText}"
                                   Visibility="{Binding Library.HasSearchStatus, Converter={StaticResource Dyc.BoolToVisibility}}" />
                        <ListBox x:Name="LibraryResults"
                                 Margin="2,0,2,2"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 FontSize="13"
                                 Foreground="{StaticResource Dyc.TextBrush}"
                                 ItemsSource="{Binding Library.SearchResults}"
                                 ItemContainerStyle="{StaticResource Dyc.LibraryResultItemStyle}"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.VirtualizationMode="Recycling"
                                 PreviewMouseLeftButtonDown="OnLibraryMouseDown"
                                 PreviewMouseMove="OnLibraryMouseMove"
                                 MouseDoubleClick="OnLibraryResultsDoubleClick"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled" />
                    </DockPanel>
                </Grid>
            </DockPanel>

            <GridSplitter Grid.Column="1"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="{StaticResource Dyc.PanelBorderBrush}" />

            <!-- Node canvas -->
            <nodify:NodifyEditor x:Name="Editor"
                                 Grid.Column="2"
                                 ItemsSource="{Binding Items}"
                                 Connections="{Binding Connections}"
                                 SelectedItems="{Binding SelectedItems}"
                                 SelectedConnections="{Binding SelectedConnections}"
                                 PendingConnection="{Binding PendingConnection}"
                                 PendingConnectionTemplate="{StaticResource Dyc.PendingConnectionTemplate}"
                                 ConnectionTemplate="{StaticResource Dyc.ConnectionTemplate}"
                                 DisconnectConnectorCommand="{Binding DisconnectConnectorCommand}"
                                 RemoveConnectionCommand="{Binding RemoveConnectionCommand}"
                                 ItemContainerStyle="{StaticResource Dyc.ItemContainerStyle}"
                                 GridCellSize="15"
                                 AllowDrop="True"
                                 Drop="OnEditorDrop"
                                 PreviewMouseDown="OnEditorPreviewMouseDown">

                <nodify:NodifyEditor.Background>
                    <DrawingBrush TileMode="Tile"
                                  ViewportUnits="Absolute"
                                  Viewport="0 0 15 15"
                                  Transform="{Binding ViewportTransform, ElementName=Editor}">
                        <DrawingBrush.Drawing>
                            <DrawingGroup>
                                <GeometryDrawing Brush="{StaticResource Dyc.CanvasBrush}">
                                    <GeometryDrawing.Geometry>
                                        <RectangleGeometry Rect="0 0 15 15" />
                                    </GeometryDrawing.Geometry>
                                </GeometryDrawing>
                                <GeometryDrawing>
                                    <GeometryDrawing.Pen>
                                        <Pen Brush="{StaticResource Dyc.GridLineBrush}" Thickness="0.6" />
                                    </GeometryDrawing.Pen>
                                    <GeometryDrawing.Geometry>
                                        <GeometryGroup>
                                            <LineGeometry StartPoint="0,0" EndPoint="15,0" />
                                            <LineGeometry StartPoint="0,0" EndPoint="0,15" />
                                        </GeometryGroup>
                                    </GeometryDrawing.Geometry>
                                </GeometryDrawing>
                            </DrawingGroup>
                        </DrawingBrush.Drawing>
                    </DrawingBrush>
                </nodify:NodifyEditor.Background>

                <nodify:NodifyEditor.InputBindings>
                    <KeyBinding Key="Delete" Command="{Binding DeleteSelectionCommand}" />
                </nodify:NodifyEditor.InputBindings>

                <nodify:NodifyEditor.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Add Note Here"
                                  Command="{Binding PlacementTarget.DataContext.AddNoteCommand, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}"
                                  CommandParameter="{Binding PlacementTarget.MouseLocation, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" />
                        <Separator />
                        <MenuItem Header="Copy"
                                  InputGestureText="Ctrl+C"
                                  Command="{Binding PlacementTarget.DataContext.CopySelectionCommand, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" />
                        <MenuItem Header="Paste"
                                  InputGestureText="Ctrl+V"
                                  Command="{Binding PlacementTarget.DataContext.PasteCommand, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" />
                        <MenuItem Header="Duplicate"
                                  InputGestureText="Ctrl+D"
                                  Command="{Binding PlacementTarget.DataContext.DuplicateSelectionCommand, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" />
                        <MenuItem Header="Group Selection"
                                  InputGestureText="Ctrl+G"
                                  Command="{Binding PlacementTarget.DataContext.GroupSelectionCommand, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" />
                        <Separator />
                        <MenuItem Header="Run"
                                  Command="{Binding PlacementTarget.DataContext.RunCommand, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" />
                        <MenuItem Header="Fit to Screen"
                                  Command="{x:Static nodify:EditorCommands.FitToScreen}"
                                  CommandTarget="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType={x:Type ContextMenu}}}" />
                    </ContextMenu>
                </nodify:NodifyEditor.ContextMenu>
            </nodify:NodifyEditor>

            <!-- Quick node search (Space over the canvas): type, ↑/↓ to pick,
                 Enter inserts at the spot the cursor was on when it opened. -->
            <Border Grid.Column="2"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Margin="0,42,0,0"
                    Width="380"
                    Background="{StaticResource Dyc.PanelBrush}"
                    BorderBrush="{StaticResource Dyc.AccentBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="8"
                    Panel.ZIndex="900"
                    Visibility="{Binding IsQuickSearchOpen, Converter={StaticResource Dyc.BoolToVisibility}}"
                    IsKeyboardFocusWithinChanged="OnQuickSearchFocusChanged">
                <DockPanel>
                    <Grid DockPanel.Dock="Top">
                        <TextBox x:Name="QuickSearchBox"
                                 FontSize="13"
                                 Style="{StaticResource Dyc.TextBox}"
                                 Padding="26,4,8,4"
                                 Text="{Binding QuickSearchText, UpdateSourceTrigger=PropertyChanged}"
                                 PreviewKeyDown="OnQuickSearchBoxKeyDown" />
                        <Path Width="14" Height="14" Stretch="Uniform"
                              HorizontalAlignment="Left" VerticalAlignment="Center"
                              Margin="7,0,0,0"
                              IsHitTestVisible="False"
                              Fill="{StaticResource Dyc.SubtleTextBrush}"
                              Data="{StaticResource Dyc.Icon.Search}" />
                    </Grid>
                    <TextBlock DockPanel.Dock="Top"
                               Margin="2,5,2,3"
                               FontSize="10"
                               Foreground="{StaticResource Dyc.SubtleTextBrush}"
                               Text="↑↓ choose · Enter inserts the node · Esc closes" />
                    <ListBox x:Name="QuickSearchList"
                             MaxHeight="300"
                             Background="Transparent"
                             BorderThickness="0"
                             FontSize="13"
                             Foreground="{StaticResource Dyc.TextBrush}"
                             ItemsSource="{Binding QuickSearchResults}"
                             SelectedItem="{Binding QuickSearchSelected, Mode=TwoWay}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling"
                             PreviewMouseLeftButtonUp="OnQuickSearchListClick">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="{x:Type ListBoxItem}">
                                <Setter Property="Foreground" Value="{StaticResource Dyc.TextBrush}" />
                                <Setter Property="Padding" Value="6,3" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type ListBoxItem}">
                                            <Border x:Name="Chrome"
                                                    Background="Transparent"
                                                    BorderBrush="Transparent"
                                                    BorderThickness="1,0,0,0"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Chrome" Property="Background" Value="{StaticResource Dyc.HoverBrush}" />
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Chrome" Property="Background" Value="{StaticResource Dyc.HoverBrush}" />
                                                    <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource Dyc.AccentBrush}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel ToolTipService.ShowDuration="30000"
                                            ToolTipService.InitialShowDelay="400">
                                    <StackPanel.ToolTip>
                                        <ToolTip MaxWidth="380">
                                            <StackPanel Margin="2">
                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding Description}"
                                                           Margin="0,6,0,0"
                                                           TextWrapping="Wrap"
                                                           Visibility="{Binding HasDescription, Converter={StaticResource Dyc.BoolToVisibility}}" />
                                                <TextBlock Text="{Binding Signature}"
                                                           Margin="0,6,0,0"
                                                           FontStyle="Italic"
                                                           Opacity="0.85"
                                                           TextWrapping="Wrap"
                                                           Visibility="{Binding HasSignature, Converter={StaticResource Dyc.BoolToVisibility}}" />
                                            </StackPanel>
                                        </ToolTip>
                                    </StackPanel.ToolTip>
                                    <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding Category}"
                                               FontSize="10"
                                               Foreground="{StaticResource Dyc.SubtleTextBrush}"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Busy overlay over the canvas. Graph runs are synchronous on the UI
                 thread (Navisworks nodes must run on the host's main thread), so
                 this appears just before the thread blocks to signal "working",
                 alongside the wait cursor set in code-behind. -->
            <Border Grid.Column="2"
                    Background="#66000000"
                    Visibility="{Binding IsRunning, Converter={StaticResource Dyc.BoolToVisibility}}"
                    Panel.ZIndex="1000">
                <Border HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="{StaticResource Dyc.PanelBrush}"
                        BorderBrush="{StaticResource Dyc.AccentBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="20,14">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⏳"
                                   FontSize="16"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0" />
                        <TextBlock Text="Running the graph…"
                                   Foreground="{StaticResource Dyc.TextBrush}"
                                   FontSize="13"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
