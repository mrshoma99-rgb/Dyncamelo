<Window x:Class="Dyncamelo.UI.Views.TextInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        SizeToContent="Height"
        Width="380"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Dyncamelo.UI;component/Themes/DyncameloDark.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="{StaticResource Dyc.PanelBrush}"
            BorderBrush="{StaticResource Dyc.PanelBorderBrush}"
            BorderThickness="1"
            CornerRadius="6">
        <StackPanel Margin="18">
            <TextBlock x:Name="TitleText"
                       MouseLeftButtonDown="OnHeaderMouseDown"
                       Foreground="{StaticResource Dyc.TextBrush}"
                       FontSize="15"
                       FontWeight="SemiBold"
                       Text="Rename" />
            <TextBlock x:Name="MessageText"
                       Margin="0,10,0,4"
                       Foreground="{StaticResource Dyc.SubtleTextBrush}"
                       TextWrapping="Wrap"
                       Text="New name:" />
            <TextBox x:Name="ResponseBox"
                     Style="{StaticResource Dyc.TextBox}"
                     FontSize="13"
                     KeyDown="OnResponseKeyDown" />
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,16,0,0">
                <Button Style="{StaticResource Dyc.ToolButton}"
                        BorderBrush="{StaticResource Dyc.InputBorderBrush}"
                        Content="Cancel"
                        MinWidth="72"
                        Click="OnCancelClick" />
                <Button Style="{StaticResource Dyc.ToolButton}"
                        BorderBrush="{StaticResource Dyc.AccentBrush}"
                        Foreground="{StaticResource Dyc.AccentBrush}"
                        Content="OK"
                        MinWidth="72"
                        Margin="8,0,0,0"
                        Click="OnOkClick" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
