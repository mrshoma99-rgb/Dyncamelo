<Window x:Class="Dyncamelo.UI.Views.ColorPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Dyncamelo.UI;component/Themes/DyncameloDark.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="{StaticResource Dyc.PanelBrush}"
            BorderBrush="{StaticResource Dyc.PanelBorderBrush}"
            BorderThickness="1"
            CornerRadius="6">
        <StackPanel Margin="18" Width="292">
            <TextBlock MouseLeftButtonDown="OnHeaderMouseDown"
                       Foreground="{StaticResource Dyc.TextBrush}"
                       FontSize="15" FontWeight="SemiBold" Text="Pick a colour" />

            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                <!-- Saturation / value square -->
                <Border x:Name="SvSquare" Width="200" Height="160" CornerRadius="3"
                        ClipToBounds="True"
                        BorderBrush="{StaticResource Dyc.InputBorderBrush}" BorderThickness="1"
                        MouseLeftButtonDown="OnSvMouseDown" MouseMove="OnSvMouseMove"
                        MouseLeftButtonUp="OnSurfaceMouseUp">
                    <Grid>
                        <Border x:Name="SvHue" />
                        <Border>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#FFFFFFFF" Offset="0" />
                                    <GradientStop Color="#00FFFFFF" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <Border>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#00000000" Offset="0" />
                                    <GradientStop Color="#FF000000" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <Canvas>
                            <Ellipse x:Name="SvThumb" Width="12" Height="12"
                                     Stroke="White" StrokeThickness="2" IsHitTestVisible="False">
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="Black" BlurRadius="3" ShadowDepth="0" Opacity="0.6" />
                                </Ellipse.Effect>
                            </Ellipse>
                        </Canvas>
                    </Grid>
                </Border>

                <!-- Hue bar -->
                <Border x:Name="HueBar" Width="20" Height="160" CornerRadius="3" Margin="10,0,0,0"
                        ClipToBounds="True"
                        BorderBrush="{StaticResource Dyc.InputBorderBrush}" BorderThickness="1"
                        MouseLeftButtonDown="OnHueMouseDown" MouseMove="OnHueMouseMove"
                        MouseLeftButtonUp="OnSurfaceMouseUp">
                    <Grid>
                        <Border>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#FFFF0000" Offset="0" />
                                    <GradientStop Color="#FFFFFF00" Offset="0.1667" />
                                    <GradientStop Color="#FF00FF00" Offset="0.3333" />
                                    <GradientStop Color="#FF00FFFF" Offset="0.5" />
                                    <GradientStop Color="#FF0000FF" Offset="0.6667" />
                                    <GradientStop Color="#FFFF00FF" Offset="0.8333" />
                                    <GradientStop Color="#FFFF0000" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <Canvas>
                            <Border x:Name="HueThumb" Width="20" Height="4" Background="White"
                                    CornerRadius="1" IsHitTestVisible="False">
                                <Border.Effect>
                                    <DropShadowEffect Color="Black" BlurRadius="2" ShadowDepth="0" Opacity="0.6" />
                                </Border.Effect>
                            </Border>
                        </Canvas>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- Preview + hex -->
            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="46" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Height="30" CornerRadius="3"
                        BorderBrush="{StaticResource Dyc.InputBorderBrush}" BorderThickness="1">
                    <Border.Background>
                        <SolidColorBrush x:Name="PreviewBrush" />
                    </Border.Background>
                </Border>
                <TextBox x:Name="HexBox" Grid.Column="1" Margin="8,0,0,0"
                         Style="{StaticResource Dyc.TextBox}" VerticalContentAlignment="Center"
                         ToolTip="#RRGGBB or #AARRGGBB"
                         LostKeyboardFocus="OnHexChanged" KeyDown="OnHexKeyDown" />
            </Grid>

            <!-- A R G B channels -->
            <Grid Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,3,0">
                    <TextBlock Text="A" FontSize="10" Foreground="{StaticResource Dyc.SubtleTextBrush}" />
                    <TextBox x:Name="ABox" Style="{StaticResource Dyc.TextBox}" FontSize="11"
                             LostKeyboardFocus="OnChannelChanged" KeyDown="OnChannelKeyDown" />
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="3,0">
                    <TextBlock Text="R" FontSize="10" Foreground="{StaticResource Dyc.SubtleTextBrush}" />
                    <TextBox x:Name="RBox" Style="{StaticResource Dyc.TextBox}" FontSize="11"
                             LostKeyboardFocus="OnChannelChanged" KeyDown="OnChannelKeyDown" />
                </StackPanel>
                <StackPanel Grid.Column="2" Margin="3,0">
                    <TextBlock Text="G" FontSize="10" Foreground="{StaticResource Dyc.SubtleTextBrush}" />
                    <TextBox x:Name="GBox" Style="{StaticResource Dyc.TextBox}" FontSize="11"
                             LostKeyboardFocus="OnChannelChanged" KeyDown="OnChannelKeyDown" />
                </StackPanel>
                <StackPanel Grid.Column="3" Margin="3,0,0,0">
                    <TextBlock Text="B" FontSize="10" Foreground="{StaticResource Dyc.SubtleTextBrush}" />
                    <TextBox x:Name="BBox" Style="{StaticResource Dyc.TextBox}" FontSize="11"
                             LostKeyboardFocus="OnChannelChanged" KeyDown="OnChannelKeyDown" />
                </StackPanel>
            </Grid>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Style="{StaticResource Dyc.ToolButton}"
                        BorderBrush="{StaticResource Dyc.InputBorderBrush}"
                        Content="Cancel" MinWidth="72" Click="OnCancelClick" />
                <Button Style="{StaticResource Dyc.ToolButton}"
                        BorderBrush="{StaticResource Dyc.AccentBrush}"
                        Foreground="{StaticResource Dyc.AccentBrush}"
                        Content="OK" MinWidth="72" Margin="8,0,0,0" Click="OnOkClick" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
