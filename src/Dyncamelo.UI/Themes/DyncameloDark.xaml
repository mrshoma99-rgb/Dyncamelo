    <!-- Reusable toolbar icon: 13px, filled with the text colour, spaced before a label. -->
    <Style x:Key="Dyc.ToolIcon" TargetType="{x:Type Path}">
        <Setter Property="Stretch" Value="Uniform" />
        <Setter Property="Width" Value="13" />
        <Setter Property="Height" Value="13" />
        <Setter Property="Fill" Value="{StaticResource Dyc.TextBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="0,0,5,0" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>


    <!-- ===== Menus & tooltips follow the palette (else they keep system/Nodify
         colours and go white-on-white when the Light palette is active). ===== -->
    <Style TargetType="{x:Type ToolTip}">
        <Setter Property="Background" Value="{StaticResource Dyc.PanelBrush}" />
        <Setter Property="Foreground" Value="{StaticResource Dyc.TextBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource Dyc.PanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="8,5" />
    </Style>
    <!-- Retemplated so the default WPF ContextMenu chrome is gone: the stock
         template paints a light "icon gutter" strip down the left edge that,
         over the dark panel, shows as a white stripe overlapping the items.
         This template is just the themed border + items (matching the submenu
         popup below), so there is no gutter. -->
    <Style TargetType="{x:Type ContextMenu}">
        <Setter Property="Background" Value="{StaticResource Dyc.PanelBrush}" />
        <Setter Property="Foreground" Value="{StaticResource Dyc.TextBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource Dyc.PanelBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ContextMenu}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="3"
                            SnapsToDevicePixels="True">
                        <ScrollViewer CanContentScroll="True">
                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle" />
                        </ScrollViewer>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <!-- Fully themed menu item. Crucially it templates the SUBMENU popup with a
         dark themed border — WPF's default leaves that popup system-white, which
         with light text reads white-on-white (the Open ▾ Recent/Sample lists).
         Keyed so the explicit menu styles in the view can inherit it via BasedOn. -->
    <Style x:Key="Dyc.MenuItem" TargetType="{x:Type MenuItem}">
        <Setter Property="Foreground" Value="{StaticResource Dyc.TextBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type MenuItem}">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            Margin="2,1"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Path x:Name="Check"
                                  Grid.Column="0"
                                  VerticalAlignment="Center" HorizontalAlignment="Center"
                                  Data="M0,4 L3,7 L8,0"
                                  Stroke="{StaticResource Dyc.AccentBrush}"
                                  StrokeThickness="1.6"
                                  Visibility="Collapsed" />
                            <ContentPresenter x:Name="HeaderHost"
                                              Grid.Column="1"
                                              ContentSource="Header"
                                              RecognizesAccessKey="True"
                                              VerticalAlignment="Center"
                                              Margin="4,5,10,5" />
                            <TextBlock Grid.Column="2"
                                       Text="{TemplateBinding InputGestureText}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"
                                       Foreground="{StaticResource Dyc.SubtleTextBrush}" />
                            <Path x:Name="Arrow"
                                  Grid.Column="3"
                                  VerticalAlignment="Center"
                                  Margin="0,0,8,0"
                                  Data="M0,0 L4,4 L0,8 Z"
                                  Fill="{StaticResource Dyc.SubtleTextBrush}"
                                  Visibility="Collapsed" />
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Placement="Right"
                                   HorizontalOffset="-2"
                                   IsOpen="{TemplateBinding IsSubmenuOpen}"
                                   Focusable="False"
                                   PopupAnimation="None">
                                <Border Background="{StaticResource Dyc.PanelBrush}"
                                        BorderBrush="{StaticResource Dyc.PanelBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="3"
                                        SnapsToDevicePixels="True">
                                    <ScrollViewer CanContentScroll="True">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Role" Value="SubmenuHeader">
                            <Setter TargetName="Arrow" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="Role" Value="TopLevelHeader">
                            <Setter TargetName="Arrow" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Check" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource Dyc.HoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <!-- Apply the themed item to every menu that doesn't set its own style. -->
    <Style TargetType="{x:Type MenuItem}" BasedOn="{StaticResource Dyc.MenuItem}" />
    <Style TargetType="{x:Type Separator}">
        <Setter Property="Background" Value="{StaticResource Dyc.PanelBorderBrush}" />
    </Style>

    <!-- ===== Small controls used inside nodes and the chrome =====
         Rounded, flat field matching the BIMCamel TextBox (CornerRadius 6, accent
         focus ring). Templated so the corners actually round. -->
    <Style x:Key="Dyc.TextBox" TargetType="{x:Type TextBox}">
        <Setter Property="Background" Value="{StaticResource Dyc.InputBackgroundBrush}" />
        <Setter Property="Foreground" Value="{StaticResource Dyc.TextBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource Dyc.InputBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CaretBrush" Value="{StaticResource Dyc.TextBrush}" />
        <Setter Property="SelectionBrush" Value="{StaticResource Dyc.AccentBrush}" />
        <Setter Property="Padding" Value="6,3" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TextBox}">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6">
                        <!-- No forced VerticalAlignment: single-line boxes centre via
                             VerticalContentAlignment; multiline Watch boxes fill and scroll. -->
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Dyc.AccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== Themed dropdown for inline choice/enum input ports =====
         Rounded flat field matching Dyc.TextBox, a dark popup list with hover
         highlight. Used by the NodeInput header for ports that declare a fixed
         set of choices (selection levels, clash types, export schemas, ...). -->
    <Style x:Key="Dyc.ComboBoxToggle" TargetType="{x:Type ToggleButton}">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="ClickMode" Value="Press" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <Border x:Name="Bd"
                            Background="{StaticResource Dyc.InputBackgroundBrush}"
                            BorderBrush="{StaticResource Dyc.InputBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6">
                        <Path x:Name="Arrow"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Center"
                              Margin="0,0,7,0"
                              Data="M0,0 L4,4 L8,0 Z"
                              Fill="{StaticResource Dyc.SubtleTextBrush}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Dyc.AccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Dyc.AccentBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Dyc.ComboBoxItem" TargetType="{x:Type ComboBoxItem}">
        <Setter Property="Foreground" Value="{StaticResource Dyc.TextBrush}" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                    <Border x:Name="Bd" Background="Transparent" Padding="{TemplateBinding Padding}">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource Dyc.HoverBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Dyc.ComboBox" TargetType="{x:Type ComboBox}">
        <Setter Property="Foreground" Value="{StaticResource Dyc.TextBrush}" />
        <Setter Property="Background" Value="{StaticResource Dyc.InputBackgroundBrush}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Height" Value="22" />
        <Setter Property="ItemContainerStyle" Value="{StaticResource Dyc.ComboBoxItem}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ComboBox}">
                    <Grid>
                        <ToggleButton x:Name="ToggleButton"
                                      Style="{StaticResource Dyc.ComboBoxToggle}"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" />
                        <ContentPresenter x:Name="ContentSite"
                                          IsHitTestVisible="False"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          Margin="8,0,20,0"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Left"
                                          TextElement.Foreground="{StaticResource Dyc.TextBrush}" />
                        <Popup x:Name="PART_Popup"
                               AllowsTransparency="True"
                               Placement="Bottom"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               Focusable="False"
                               PopupAnimation="Slide">
                            <Border Background="{StaticResource Dyc.PanelBrush}"
                                    BorderBrush="{StaticResource Dyc.PanelBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Margin="0,2,0,0"
                                    MaxHeight="220"
                                    MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                <ScrollViewer>
                                    <ItemsPresenter />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Compact icon-only button (square, rounded) for chrome affordances such as
         the library expand/collapse controls next to the search box. -->
    <Style x:Key="Dyc.IconButton" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource Dyc.SubtleTextBrush}" />
        <Setter Property="Width" Value="26" />
        <Setter Property="Height" Value="26" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="Chrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{StaticResource Dyc.InputBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{StaticResource Dyc.HoverBrush}" />
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource Dyc.AccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{StaticResource Dyc.InputBackgroundBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Dyc.ToolButton" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource Dyc.TextBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="Margin" Value="1,0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="Chrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{StaticResource Dyc.HoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{StaticResource Dyc.InputBackgroundBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Dyc.ToolToggle" TargetType="{x:Type ToggleButton}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource Dyc.TextBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="Margin" Value="1,0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <Border x:Name="Chrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{StaticResource Dyc.HoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{StaticResource Dyc.HoverBrush}" />
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource Dyc.AccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Dyc.SmallButton" TargetType="{x:Type Button}" BasedOn="{StaticResource Dyc.ToolButton}">
        <Setter Property="Padding" Value="6,1" />
        <Setter Property="BorderBrush" Value="{StaticResource Dyc.InputBorderBrush}" />
    </Style>

    <Style x:Key="Dyc.SmallToggle" TargetType="{x:Type ToggleButton}" BasedOn="{StaticResource Dyc.ToolToggle}">
        <Setter Property="Padding" Value="6,1" />
        <Setter Property="BorderBrush" Value="{StaticResource Dyc.InputBorderBrush}" />
    </Style>

    <!-- A full-width selectable row in the settings panel; the selected option
         (ChoiceOption.IsSelected) shows an accent border. -->
    <Style x:Key="Dyc.SettingsChoice" TargetType="{x:Type Button}">
        <Setter Property="Foreground" Value="{StaticResource Dyc.TextBrush}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="Margin" Value="0,1" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="Chrome"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="1"
                            CornerRadius="3"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{StaticResource Dyc.HoverBrush}" />
                        </Trigger>
                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{StaticResource Dyc.HoverBrush}" />
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource Dyc.AccentBrush}" />
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== Library search results (flat Dynamo-style list while searching) ===== -->
    <Style x:Key="Dyc.LibraryResultItemStyle" TargetType="{x:Type ListBoxItem}">
        <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
        <Setter Property="Foreground" Value="{StaticResource Dyc.TextBrush}" />
        <Setter Property="Padding" Value="4,2" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ListBoxItem}">
                    <Border x:Name="Chrome"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="1,0,0,0"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{StaticResource Dyc.HoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Chrome" Property="Background" Value="{StaticResource Dyc.HoverBrush}" />
                            <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource Dyc.AccentBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== Canvas item container (nodes + notes + groups) =====
         Nodify's default ItemContainer style draws a 1px DodgerBlue border
         around EVERY container (BorderBrush setter in Controls.xaml resolving
         ItemContainer.BorderBrush/BorderColor from the Dark theme). Kill it for
         unselected items by overriding the container's BorderBrush; the
         selected/previewing-selection triggers still swap the border to
         SelectedBrush (verified against the 7.3.0 ItemContainer template),
         which we soften to a subtle accent. Warning/error state borders are
         drawn by the node template itself and remain untouched. -->
    <Style x:Key="Dyc.ItemContainerStyle" TargetType="{x:Type nodify:ItemContainer}"
           BasedOn="{StaticResource {x:Type nodify:ItemContainer}}">
        <Setter Property="Location" Value="{Binding Location, Mode=TwoWay}" />
        <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
        <Setter Property="ActualSize" Value="{Binding Size, Mode=OneWayToSource}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="SelectedBrush" Value="{StaticResource Dyc.SelectionBorderBrush}" />
        <Setter Property="HighlightBrush" Value="{StaticResource Dyc.SelectionBorderBrush}" />
    </Style>

    <!-- ===== Connector (port) visuals: required inputs are filled, inputs with a
         default value are hollow/dimmed. Both light up when connected. ===== -->
    <ControlTemplate x:Key="Dyc.RequiredConnectorTemplate" TargetType="{x:Type Control}">
        <Ellipse x:Name="Dot"
                 Width="11" Height="11"
                 Fill="{StaticResource Dyc.WireBrush}"
                 Stroke="{StaticResource Dyc.WireBrush}"
                 StrokeThickness="1.5" />
        <ControlTemplate.Triggers>
            <DataTrigger Binding="{Binding IsConnected}" Value="True">
                <Setter TargetName="Dot" Property="Fill" Value="{StaticResource Dyc.AccentBrush}" />
                <Setter TargetName="Dot" Property="Stroke" Value="{StaticResource Dyc.AccentBrush}" />
            </DataTrigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate x:Key="Dyc.OptionalConnectorTemplate" TargetType="{x:Type Control}">
        <Ellipse x:Name="Dot"
                 Width="11" Height="11"
                 Fill="Transparent"
                 Stroke="{StaticResource Dyc.SubtleTextBrush}"
                 StrokeThickness="1.5" />
        <ControlTemplate.Triggers>
            <DataTrigger Binding="{Binding IsConnected}" Value="True">
                <Setter TargetName="Dot" Property="Fill" Value="{StaticResource Dyc.AccentBrush}" />
                <Setter TargetName="Dot" Property="Stroke" Value="{StaticResource Dyc.AccentBrush}" />
            </DataTrigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style TargetType="{x:Type nodify:NodeInput}" BasedOn="{StaticResource {x:Type nodify:NodeInput}}">
        <Setter Property="Header" Value="{Binding}" />
        <Setter Property="IsConnected" Value="{Binding IsConnected}" />
        <Setter Property="Anchor" Value="{Binding Anchor, Mode=OneWayToSource}" />
        <Setter Property="ToolTip" Value="{Binding ToolTip}" />
        <Setter Property="ConnectorTemplate" Value="{StaticResource Dyc.RequiredConnectorTemplate}" />
        <Setter Property="ContextMenu">
            <Setter.Value>
                <ContextMenu>
                    <MenuItem Header="Disconnect" Command="{Binding DisconnectCommand}" />
                </ContextMenu>
            </Setter.Value>
        </Setter>
        <Setter Property="HeaderTemplate">
            <Setter.Value>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Title}"
                                   Foreground="{StaticResource Dyc.TextBrush}"
                                   FontSize="11"
                                   VerticalAlignment="Center" />
                        <!-- Inline dropdown for unconnected choice ports (selection
                             levels, clash types, ...); collapsed for every other port. -->
                        <ComboBox Style="{StaticResource Dyc.ComboBox}"
                                  Margin="6,0,0,0"
                                  MinWidth="96"
                                  ItemsSource="{Binding Choices}"
                                  SelectedItem="{Binding SelectedChoice, Mode=TwoWay}"
                                  Visibility="{Binding ShowChoiceEditor, Converter={StaticResource Dyc.BoolToVisibility}}" />
                    </StackPanel>
                </DataTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsOptional}" Value="True">
                <Setter Property="ConnectorTemplate" Value="{StaticResource Dyc.OptionalConnectorTemplate}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="{x:Type nodify:NodeOutput}" BasedOn="{StaticResource {x:Type nodify:NodeOutput}}">
        <Setter Property="Header" Value="{Binding}" />
        <Setter Property="IsConnected" Value="{Binding IsConnected}" />
        <Setter Property="Anchor" Value="{Binding Anchor, Mode=OneWayToSource}" />
        <Setter Property="ToolTip" Value="{Binding ToolTip}" />
        <Setter Property="ConnectorTemplate" Value="{StaticResource Dyc.RequiredConnectorTemplate}" />
        <Setter Property="ContextMenu">
            <Setter.Value>
                <ContextMenu>
                    <MenuItem Header="Disconnect" Command="{Binding DisconnectCommand}" />
                </ContextMenu>
            </Setter.Value>
        </Setter>
        <Setter Property="HeaderTemplate">
            <Setter.Value>
                <DataTemplate>
                    <TextBlock Text="{Binding Title}"
                               Foreground="{StaticResource Dyc.TextBrush}"
                               FontSize="11" />
                </DataTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== Wires (click to select, Delete or context menu to remove) ===== -->
    <DataTemplate x:Key="Dyc.ConnectionTemplate" DataType="{x:Type vm:ConnectionViewModel}">
        <nodify:Connection nodify:BaseConnection.IsSelectable="True"
                           Source="{Binding Source.Anchor}"
                           Target="{Binding Target.Anchor}"
                           SourceOffsetMode="Edge"
                           TargetOffsetMode="Edge">
            <nodify:Connection.Style>
                <Style TargetType="{x:Type nodify:Connection}" BasedOn="{StaticResource {x:Type nodify:Connection}}">
                    <Setter Property="Stroke" Value="{StaticResource Dyc.WireBrush}" />
                    <Setter Property="StrokeThickness" Value="2" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                            <Setter Property="Stroke" Value="{StaticResource Dyc.AccentBrush}" />
                            <Setter Property="StrokeThickness" Value="3" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </nodify:Connection.Style>
            <nodify:Connection.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Disconnect" Command="{Binding DisconnectCommand}" />
                </ContextMenu>
            </nodify:Connection.ContextMenu>
        </nodify:Connection>
    </DataTemplate>

    <DataTemplate x:Key="Dyc.PendingConnectionTemplate" DataType="{x:Type vm:PendingConnectionViewModel}">
        <nodify:PendingConnection IsVisible="{Binding IsVisible}"
                                  Source="{Binding Source, Mode=OneWayToSource}"
                                  Target="{Binding Target, Mode=OneWayToSource}"
                                  TargetAnchor="{Binding TargetLocation, Mode=OneWayToSource}"
                                  EnableSnapping="True"
                                  AllowOnlyConnectors="True"
                                  Stroke="{StaticResource Dyc.AccentBrush}"
                                  StrokeThickness="2"
                                  StartedCommand="{Binding DataContext.StartConnectionCommand, RelativeSource={RelativeSource AncestorType={x:Type nodify:NodifyEditor}}}"
                                  CompletedCommand="{Binding DataContext.CreateConnectionCommand, RelativeSource={RelativeSource AncestorType={x:Type nodify:NodifyEditor}}}" />
    </DataTemplate>

    <!-- ===== Node body (inline editor) templates, chosen by Dyc.NodeBodySelector ===== -->
    <DataTemplate x:Key="NodeBody.Empty">
        <Border Height="2" MinWidth="40" Background="Transparent" />
    </DataTemplate>

    <DataTemplate x:Key="NodeBody.NumberInput">
        <TextBox Style="{StaticResource Dyc.TextBox}"
                 MinWidth="90"
                 Margin="4"
                 Text="{Binding Value}" />
    </DataTemplate>

    <DataTemplate x:Key="NodeBody.NumberSlider">
        <StackPanel Margin="4" MinWidth="200">
            <TextBox Style="{StaticResource Dyc.TextBox}"
                     HorizontalAlignment="Stretch"
                     Text="{Binding Value}" />
            <Grid Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="44" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="44" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Style="{StaticResource Dyc.TextBox}"
                         FontSize="10"
                         Text="{Binding Min}"
                         ToolTip="Minimum" />
                <Slider Grid.Column="1"
                        Margin="4,0"
                        VerticalAlignment="Center"
                        Minimum="{Binding Min}"
                        Maximum="{Binding Max}"
                        Value="{Binding Value}"
                        IsSnapToTickEnabled="True"
                        TickFrequency="{Binding Step}" />
                <TextBlock Grid.Column="2"
                           Margin="0,0,4,0"
                           VerticalAlignment="Center"
                           MinWidth="30"
                           TextAlignment="Right"
                           FontSize="10"
                           Foreground="{StaticResource Dyc.AccentBrush}"
                           ToolTip="Current value"
                           Text="{Binding Value, StringFormat={}{0:0.###}}" />
                <TextBox Grid.Column="3"
                         Style="{StaticResource Dyc.TextBox}"
                         FontSize="10"
                         Text="{Binding Max}"
                         ToolTip="Maximum" />
            </Grid>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
                <TextBlock Text="step" VerticalAlignment="Center" FontSize="10"
                           Foreground="{StaticResource Dyc.SubtleTextBrush}" Margin="0,0,4,0" />
                <TextBox Style="{StaticResource Dyc.TextBox}" FontSize="10" Width="50"
                         Text="{Binding Step}" ToolTip="Step size (slider snaps to this)" />
            </StackPanel>
        </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="NodeBody.IntegerSlider">
        <StackPanel Margin="4" MinWidth="200">
            <TextBox Style="{StaticResource Dyc.TextBox}"
                     HorizontalAlignment="Stretch"
                     Text="{Binding Value}" />
            <Grid Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="44" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="44" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Style="{StaticResource Dyc.TextBox}"
                         FontSize="10"
                         Text="{Binding Min}"
                         ToolTip="Minimum" />
                <Slider Grid.Column="1"
                        Margin="4,0"
                        VerticalAlignment="Center"
                        Minimum="{Binding Min}"
                        Maximum="{Binding Max}"
                        Value="{Binding Value}"
                        IsSnapToTickEnabled="True"
                        TickFrequency="{Binding Step}" />
                <TextBlock Grid.Column="2"
                           Margin="0,0,4,0"
                           VerticalAlignment="Center"
                           MinWidth="30"
                           TextAlignment="Right"
                           FontSize="10"
                           Foreground="{StaticResource Dyc.AccentBrush}"
                           ToolTip="Current value"
                           Text="{Binding Value}" />
                <TextBox Grid.Column="3"
                         Style="{StaticResource Dyc.TextBox}"
                         FontSize="10"
                         Text="{Binding Max}"
                         ToolTip="Maximum" />
            </Grid>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,0">
                <TextBlock Text="step" VerticalAlignment="Center" FontSize="10"
                           Foreground="{StaticResource Dyc.SubtleTextBrush}" Margin="0,0,4,0" />
                <TextBox Style="{StaticResource Dyc.TextBox}" FontSize="10" Width="50"
                         Text="{Binding Step}" ToolTip="Step size (slider snaps to this)" />
            </StackPanel>
        </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="NodeBody.StringInput">
        <TextBox Style="{StaticResource Dyc.TextBox}"
                 MinWidth="130"
                 MaxWidth="260"
                 Margin="4"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 Text="{Binding Value}" />
    </DataTemplate>

    <DataTemplate x:Key="NodeBody.BooleanToggle">
        <CheckBox Margin="6,4"
                  Foreground="{StaticResource Dyc.TextBrush}"
                  IsChecked="{Binding Value}"
                  Content="{Binding Value}" />
    </DataTemplate>

    <DataTemplate x:Key="NodeBody.FilePath">
        <DockPanel Margin="4" MinWidth="170">
            <Button DockPanel.Dock="Right"
                    Style="{StaticResource Dyc.SmallButton}"
                    Margin="4,0,0,0"
                    Content="…"
                    ToolTip="Browse for a file"
                    Command="{Binding DataContext.BrowseFileCommand, RelativeSource={RelativeSource AncestorType={x:Type nodify:Node}}}" />
            <TextBox Style="{StaticResource Dyc.TextBox}" Text="{Binding Path}" />
        </DockPanel>
    </DataTemplate>

    <DataTemplate x:Key="NodeBody.DirectoryPath">
        <TextBox Style="{StaticResource Dyc.TextBox}"
                 MinWidth="170"
                 Margin="4"
                 Text="{Binding Path}"
                 ToolTip="Type or paste a directory path" />
    </DataTemplate>

    <DataTemplate x:Key="NodeBody.Watch">
        <Grid Margin="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0"
                       Margin="1,0,1,3"
                       FontSize="10"
                       Foreground="{StaticResource Dyc.SubtleTextBrush}"
                       Text="{Binding DataContext.WatchCountText, RelativeSource={RelativeSource AncestorType={x:Type nodify:Node}}}"
                       Visibility="{Binding DataContext.HasWatchCount, RelativeSource={RelativeSource AncestorType={x:Type nodify:Node}}, Converter={StaticResource Dyc.BoolToVisibility}}" />
            <TextBox x:Name="WatchBox"
                     Grid.Row="1"
                     Style="{StaticResource Dyc.TextBox}"
                     MinWidth="120"
                     MinHeight="24"
                     Width="{Binding DataContext.WatchWidth, RelativeSource={RelativeSource AncestorType={x:Type nodify:Node}}}"
                     Height="{Binding DataContext.WatchHeight, RelativeSource={RelativeSource AncestorType={x:Type nodify:Node}}}"
                     MaxWidth="{Binding DataContext.WatchWidth, RelativeSource={RelativeSource AncestorType={x:Type nodify:Node}}, Converter={StaticResource Dyc.AutoSizeLimit}, ConverterParameter=280}"
                     MaxHeight="{Binding DataContext.WatchHeight, RelativeSource={RelativeSource AncestorType={x:Type nodify:Node}}, Converter={StaticResource Dyc.AutoSizeLimit}, ConverterParameter=200}"
                     FontFamily="Consolas"
                     FontSize="11"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     Text="{Binding FormattedValue, Mode=OneWay}" />
            <views:SizeGripThumb Grid.Row="2"
                                 HorizontalAlignment="Right"
                                 Width="14"
                                 Height="12"
                                 Margin="0,2,0,0"
                                 ToolTip="Drag to resize"
                                 TargetElement="{Binding ElementName=WatchBox}"
                                 TargetWidth="{Binding DataContext.WatchWidth, RelativeSource={RelativeSource AncestorType={x:Type nodify:Node}}, Mode=TwoWay}"
                                 TargetHeight="{Binding DataContext.WatchHeight, RelativeSource={RelativeSource AncestorType={x:Type nodify:Node}}, Mode=TwoWay}"
                                 MinTargetWidth="120"
                                 MinTargetHeight="24">
                <views:SizeGripThumb.Template>
                    <ControlTemplate TargetType="{x:Type views:SizeGripThumb}">
                        <Grid Background="Transparent">
                            <Path Data="M 12,2 L 2,12 M 12,7 L 7,12"
                                  Stroke="{StaticResource Dyc.SubtleTextBrush}"
                                  StrokeThickness="1.5" />
                        </Grid>
                    </ControlTemplate>
                </views:SizeGripThumb.Template>
            </views:SizeGripThumb>
        </Grid>
    </DataTemplate>

    <DataTemplate x:Key="NodeBody.Missing">
        <TextBlock Margin="6,4"
                   MaxWidth="240"
                   TextWrapping="Wrap"
                   FontSize="11"
                   Foreground="{StaticResource Dyc.ErrorBrush}"
                   Text="{Binding Reason}" />
    </DataTemplate>

    <!-- Bodies for Dyncamelo.Nodes interactive nodes (matched by type name;
         bindings resolve reflectively, so no assembly reference is needed). -->
    <DataTemplate x:Key="NodeBody.WatchListNode">
        <Grid Margin="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0"
                       Margin="1,0,1,3"
                       FontSize="10"
                       Foreground="{StaticResource Dyc.SubtleTextBrush}"
                       Text="{Binding DataContext.WatchCountText, RelativeSource={RelativeSource AncestorType={x:Type nodify:Node}}}"
                       Visibility="{Binding DataContext.HasWatchCount, RelativeSource={RelativeSource AncestorType={x:Type nodify:Node}}, Converter={StaticResource Dyc.BoolToVisibility}}" />
            <TextBox x:Name="WatchListBox"
                     Grid.Row="1"
                     Style="{StaticResource Dyc.TextBox}"
                     MinWidth="140"
                     MinHeight="24"
                     Width="{Binding DataContext.WatchWidth, RelativeSource={RelativeSource AncestorType={x:Type nodify:Node}}}"
                     Height="{Binding DataContext.WatchHeight, RelativeSource={RelativeSource AncestorType={x:Type nodify:Node}}}"
                     MaxWidth="{Binding DataContext.WatchWidth, RelativeSource={RelativeSource AncestorType={x:Type nodify:Node}}, Converter={StaticResource Dyc.AutoSizeLimit}, ConverterParameter=280}"
                     MaxHeight="{Binding DataContext.WatchHeight, RelativeSource={RelativeSource AncestorType={x:Type nodify:Node}}, Converter={StaticResource Dyc.AutoSizeLimit}, ConverterParameter=220}"
                     FontFamily="Consolas"
                     FontSize="11"
                     IsReadOnly="True"
                     VerticalScrollBarVisibility="Auto"
                     Text="{Binding FormattedValue, Mode=OneWay}" />
            <views:SizeGripThumb Grid.Row="2"
                                 HorizontalAlignment="Right"
                                 Width="14"
                                 Height="12"
                                 Margin="0,2,0,0"
                                 ToolTip="Drag to resize"
                                 TargetElement="{Binding ElementName=WatchListBox}"
                                 TargetWidth="{Binding DataContext.WatchWidth, RelativeSource={RelativeSource AncestorType={x:Type nodify:Node}}, Mode=TwoWay}"
                                 TargetHeight="{Binding DataContext.WatchHeight, RelativeSource={RelativeSource AncestorType={x:Type nodify:Node}}, Mode=TwoWay}"
                                 MinTargetWidth="140"
                                 MinTargetHeight="24">
                <views:SizeGripThumb.Template>
                    <ControlTemplate TargetType="{x:Type views:SizeGripThumb}">
                        <Grid Background="Transparent">
                            <Path Data="M 12,2 L 2,12 M 12,7 L 7,12"
                                  Stroke="{StaticResource Dyc.SubtleTextBrush}"
                                  StrokeThickness="1.5" />
                        </Grid>
                    </ControlTemplate>
                </views:SizeGripThumb.Template>
            </views:SizeGripThumb>
        </Grid>
    </DataTemplate>

    <DataTemplate x:Key="NodeBody.ListCreateNode">
        <StackPanel Orientation="Horizontal" Margin="4" HorizontalAlignment="Right">
            <Button Style="{StaticResource Dyc.SmallButton}"
                    Content="+"
                    ToolTip="Add item port"
                    Command="{Binding DataContext.AddPortCommand, RelativeSource={RelativeSource AncestorType={x:Type nodify:Node}}}" />
            <Button Style="{StaticResource Dyc.SmallButton}"
                    Margin="4,0,0,0"
                    Content="−"
                    ToolTip="Remove last item port"
                    Command="{Binding DataContext.RemovePortCommand, RelativeSource={RelativeSource AncestorType={x:Type nodify:Node}}}" />
        </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="NodeBody.ColorPickerNode">
        <StackPanel Margin="4" MinWidth="180">
            <Button Height="24" Cursor="Hand"
                    Command="{Binding DataContext.PickColorCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                    CommandParameter="{Binding}"
                    ToolTip="Open the colour picker"
                    BorderBrush="{StaticResource Dyc.InputBorderBrush}" BorderThickness="1">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border CornerRadius="3"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}">
                                        <Border.Background>
                                            <MultiBinding Converter="{StaticResource Dyc.ColorChannelsToBrush}">
                                                <Binding Path="A" />
                                                <Binding Path="R" />
                                                <Binding Path="G" />
                                                <Binding Path="B" />
                                            </MultiBinding>
                                        </Border.Background>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
            <Grid Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="A" FontSize="10" Foreground="{StaticResource Dyc.SubtleTextBrush}" VerticalAlignment="Center" />
                <Slider Grid.Row="0" Grid.Column="1" Minimum="0" Maximum="255" IsSnapToTickEnabled="True" TickFrequency="1" Value="{Binding A}" />
                <TextBlock Grid.Row="1" Grid.Column="0" Text="R" FontSize="10" Foreground="{StaticResource Dyc.SubtleTextBrush}" VerticalAlignment="Center" />
                <Slider Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="255" IsSnapToTickEnabled="True" TickFrequency="1" Value="{Binding R}" />
                <TextBlock Grid.Row="2" Grid.Column="0" Text="G" FontSize="10" Foreground="{StaticResource Dyc.SubtleTextBrush}" VerticalAlignment="Center" />
                <Slider Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="255" IsSnapToTickEnabled="True" TickFrequency="1" Value="{Binding G}" />
                <TextBlock Grid.Row="3" Grid.Column="0" Text="B" FontSize="10" Foreground="{StaticResource Dyc.SubtleTextBrush}" VerticalAlignment="Center" />
                <Slider Grid.Row="3" Grid.Column="1" Minimum="0" Maximum="255" IsSnapToTickEnabled="True" TickFrequency="1" Value="{Binding B}" />
            </Grid>
        </StackPanel>
    </DataTemplate>

    <!-- ===== Canvas item templates (implicit, picked by view-model type) ===== -->
    <DataTemplate DataType="{x:Type vm:NodeViewModel}">
        <StackPanel>
            <!-- Zero-height canvas: the diagnostics balloon floats above the node
                 without shifting its position when it appears. -->
            <Canvas Height="0" HorizontalAlignment="Left">
                <Border x:Name="Balloon"
                        Canvas.Bottom="8"
                        Canvas.Left="0"
                        Visibility="Collapsed"
                        MaxWidth="300"
                        CornerRadius="4"
                        Padding="8,5"
                        BorderThickness="1.5"
                        Background="{StaticResource Dyc.PanelBrush}"
                        BorderBrush="{StaticResource Dyc.WarningBrush}">
                    <TextBlock FontSize="11"
                               Foreground="{StaticResource Dyc.TextBrush}"
                               TextWrapping="Wrap"
                               MaxHeight="120"
                               Text="{Binding StateMessage}"
                               ToolTip="{Binding StateMessage}" />
                </Border>
            </Canvas>
            <Border x:Name="StateBorder"
                    BorderThickness="2"
                    BorderBrush="Transparent"
                    CornerRadius="6"
                    Background="Transparent">
                <Border.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Freeze"
                                  IsCheckable="True"
                                  IsChecked="{Binding IsFrozen}" />
                        <MenuItem Header="Show Preview"
                                  IsCheckable="True"
                                  IsChecked="{Binding ShowPreview}" />
                        <MenuItem Header="Lacing">
                            <MenuItem Header="Auto" Command="{Binding SetLacingCommand}" CommandParameter="Auto" />
                            <MenuItem Header="Shortest" Command="{Binding SetLacingCommand}" CommandParameter="Shortest" />
                            <MenuItem Header="Longest" Command="{Binding SetLacingCommand}" CommandParameter="Longest" />
                            <MenuItem Header="Cross Product" Command="{Binding SetLacingCommand}" CommandParameter="CrossProduct" />
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="Find in Library" Command="{Binding FindInLibraryCommand}" />
                    </ContextMenu>
                </Border.ContextMenu>
                <!-- Background colours the connector/IO strip; ContentBrush colours the
                     inline-editor area. Both must be theme brushes or half the node keeps
                     Nodify's dark default and ignores palette changes. -->
                <nodify:Node Header="{Binding}"
                             HeaderBrush="{Binding HeaderBrush}"
                             Background="{StaticResource Dyc.NodeBodyBrush}"
                             ContentBrush="{StaticResource Dyc.NodeBodyBrush}"
                             Foreground="{StaticResource Dyc.TextBrush}"
                             BorderBrush="{StaticResource Dyc.NodeBorderBrush}"
                             Input="{Binding Inputs}"
                             Output="{Binding Outputs}">
                    <nodify:Node.HeaderTemplate>
                        <DataTemplate>
                            <DockPanel MinWidth="90">
                                <TextBlock DockPanel.Dock="Right"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center"
                                           FontSize="9"
                                           Opacity="0.85"
                                           Foreground="White"
                                           Text="{Binding LacingLabel}" />
                                <!-- Function tint: Create (green) / Modify (amber) / Info (blue),
                                     so what a node does is readable at a glance on the canvas. -->
                                <Ellipse x:Name="FnDot"
                                         DockPanel.Dock="Left"
                                         Width="8" Height="8"
                                         Margin="0,0,7,0"
                                         VerticalAlignment="Center"
                                         Fill="{StaticResource Dyc.FnModifyBrush}"
                                         ToolTip="{Binding Function}" />
                                <!-- Double-click the title to rename the placed node (commits to NodeViewModel.Title -> Model.Name). -->
                                <views:EditableTextBlock FontWeight="SemiBold"
                                                         Foreground="White"
                                                         Text="{Binding Title, Mode=TwoWay}"
                                                         ToolTip="{Binding Description}" />
                            </DockPanel>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding Function}" Value="Create">
                                    <Setter TargetName="FnDot" Property="Fill" Value="{StaticResource Dyc.FnCreateBrush}" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Function}" Value="Info">
                                    <Setter TargetName="FnDot" Property="Fill" Value="{StaticResource Dyc.FnInfoBrush}" />
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </nodify:Node.HeaderTemplate>
                    <ContentControl Focusable="False"
                                    Content="{Binding Model}"
                                    ContentTemplateSelector="{StaticResource Dyc.NodeBodySelector}" />
                </nodify:Node>
            </Border>
            <!-- Dynamo-style value preview bubble (global toolbar toggle +
                 per-node "Show Preview" pin; renders after a run). -->
            <Border x:Name="PreviewBubble"
                    Margin="8,4,8,0"
                    HorizontalAlignment="Center"
                    MaxWidth="300"
                    CornerRadius="3"
                    Padding="6,3"
                    BorderThickness="1"
                    Background="{StaticResource Dyc.PanelBrush}"
                    BorderBrush="{StaticResource Dyc.PanelBorderBrush}"
                    Visibility="{Binding IsPreviewVisible, Converter={StaticResource Dyc.BoolToVisibility}}">
                <TextBlock FontSize="10"
                           FontFamily="Consolas"
                           Foreground="{StaticResource Dyc.SubtleTextBrush}"
                           TextWrapping="Wrap"
                           Text="{Binding PreviewText}"
                           ToolTip="{Binding PreviewText}" />
            </Border>
        </StackPanel>
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding State}" Value="Warning">
                <Setter TargetName="StateBorder" Property="BorderBrush" Value="{StaticResource Dyc.WarningBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding State}" Value="Error">
                <Setter TargetName="StateBorder" Property="BorderBrush" Value="{StaticResource Dyc.ErrorBrush}" />
                <Setter TargetName="Balloon" Property="BorderBrush" Value="{StaticResource Dyc.ErrorBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding HasMessage}" Value="True">
                <Setter TargetName="StateBorder" Property="ToolTip" Value="{Binding StateMessage}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding IsFrozen}" Value="True">
                <Setter TargetName="StateBorder" Property="Opacity" Value="0.45" />
            </DataTrigger>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding State}" Value="Warning" />
                    <Condition Binding="{Binding HasMessage}" Value="True" />
                </MultiDataTrigger.Conditions>
                <Setter TargetName="Balloon" Property="Visibility" Value="Visible" />
            </MultiDataTrigger>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding State}" Value="Error" />
                    <Condition Binding="{Binding HasMessage}" Value="True" />
                </MultiDataTrigger.Conditions>
                <Setter TargetName="Balloon" Property="Visibility" Value="Visible" />
            </MultiDataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <!-- ===== Groups (Dynamo-style: colored rectangle behind its nodes; dragging
         the header moves the members, the thumb resizes, title is editable) ===== -->
    <DataTemplate DataType="{x:Type vm:GroupViewModel}">
        <nodify:GroupingNode ActualSize="{Binding GroupSize, Mode=TwoWay}"
                             HeaderBrush="{Binding HeaderBrush}"
                             Background="{Binding BodyBrush}"
                             MovementMode="Group"
                             HorizontalContentAlignment="Stretch">
            <nodify:GroupingNode.Header>
                <Grid Background="Transparent" ToolTip="Drag the colored bar to move the group and its nodes">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" MinWidth="40" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             MinWidth="60"
                             MaxWidth="260"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="White"
                             CaretBrush="White"
                             FontWeight="SemiBold"
                             ToolTip="Group title (click to edit)"
                             Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
            </nodify:GroupingNode.Header>
            <nodify:GroupingNode.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Ungroup" Command="{Binding UngroupCommand}" />
                    <MenuItem Header="Color">
                        <MenuItem Header="Blue" Command="{Binding SetColorCommand}" CommandParameter="#FF3D6A99" />
                        <MenuItem Header="Green" Command="{Binding SetColorCommand}" CommandParameter="#FF3F7249" />
                        <MenuItem Header="Amber" Command="{Binding SetColorCommand}" CommandParameter="#FF9A7B2D" />
                        <MenuItem Header="Red" Command="{Binding SetColorCommand}" CommandParameter="#FF8A3B3B" />
                        <MenuItem Header="Purple" Command="{Binding SetColorCommand}" CommandParameter="#FF6B4E8E" />
                        <MenuItem Header="Gray" Command="{Binding SetColorCommand}" CommandParameter="#FF5A6273" />
                    </MenuItem>
                </ContextMenu>
            </nodify:GroupingNode.ContextMenu>
        </nodify:GroupingNode>
    </DataTemplate>

    <!-- Notes are classic yellow stickies with fixed dark text: always readable on
         either canvas, and independent of the active palette (a palette-swapped
         note background could otherwise collide with the swapped text colour). -->
    <DataTemplate DataType="{x:Type vm:NoteViewModel}">
        <Border Background="#FFFCE9A6"
                BorderBrush="#FFE6C766"
                BorderThickness="1"
                CornerRadius="4"
                Padding="8"
                MinWidth="140"
                MaxWidth="320">
            <TextBox Background="Transparent"
                     BorderThickness="0"
                     Foreground="#FF3A3320"
                     CaretBrush="#FF3A3320"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}" />
        </Border>
    </DataTemplate>

</ResourceDictionary>
