<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:nodify="https://miroiu.github.io/nodify"
                    xmlns:vm="clr-namespace:Dyncamelo.UI.ViewModels"
                    xmlns:views="clr-namespace:Dyncamelo.UI.Views">

    <!-- Nodify's dark theme supplies the default control styles this dictionary extends. -->
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/Nodify;component/Themes/Dark.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!-- ===== Dyncamelo palette — aligned to the BIMCamel design system (dark
         defaults; swapped live for the Light/Midnight/Slate palettes via
         PaletteCatalog, which mutates these same 18 brushes in place). BIMCamel
         dark tokens: Bg #15171B, Pane #1C1F24, Card #23272E, Accent #3AA0F0. ===== -->
    <SolidColorBrush x:Key="Dyc.CanvasBrush" Color="#FF15171B" />
    <SolidColorBrush x:Key="Dyc.GridLineBrush" Color="#FF20242C" />
    <SolidColorBrush x:Key="Dyc.PanelBrush" Color="#FF1C1F24" />
    <SolidColorBrush x:Key="Dyc.PanelBorderBrush" Color="#FF333941" />
    <SolidColorBrush x:Key="Dyc.NodeBodyBrush" Color="#FF23272E" />
    <SolidColorBrush x:Key="Dyc.NodeBorderBrush" Color="#FF3D444D" />
    <SolidColorBrush x:Key="Dyc.TextBrush" Color="#FFE7EAEE" />
    <SolidColorBrush x:Key="Dyc.SubtleTextBrush" Color="#FF9AA3AD" />
    <SolidColorBrush x:Key="Dyc.AccentBrush" Color="#FF3AA0F0" />
    <!-- Softened accent for the selected-node outline (subtle, not a hard rectangle). -->
    <SolidColorBrush x:Key="Dyc.SelectionBorderBrush" Color="#993AA0F0" />
    <SolidColorBrush x:Key="Dyc.WireBrush" Color="#FF7E8896" />
    <SolidColorBrush x:Key="Dyc.WarningBrush" Color="#FFF0C66A" />
    <SolidColorBrush x:Key="Dyc.ErrorBrush" Color="#FFEF5350" />
    <SolidColorBrush x:Key="Dyc.InputBackgroundBrush" Color="#FF1B1E23" />
    <SolidColorBrush x:Key="Dyc.InputBorderBrush" Color="#FF3D444D" />
    <SolidColorBrush x:Key="Dyc.HoverBrush" Color="#FF1F2D3D" />
    <SolidColorBrush x:Key="Dyc.NoteBrush" Color="#FF3A2F12" />
    <SolidColorBrush x:Key="Dyc.NoteBorderBrush" Color="#FF5C4A1E" />

    <!-- ===== BIMCamel brand chrome (constant across palettes — the product identity).
         The header is the BIMCamel blue gradient; the logo rides in a black chip so
         its baked-in black background reads as an intentional rounded badge. ===== -->
    <Color x:Key="Dyc.BrandStartColor">#0070C0</Color>
    <Color x:Key="Dyc.BrandEndColor">#0D83DA</Color>
    <SolidColorBrush x:Key="Dyc.BrandStartBrush" Color="#FF0070C0" />
    <SolidColorBrush x:Key="Dyc.BrandEndBrush" Color="#FF0D83DA" />
    <LinearGradientBrush x:Key="Dyc.BrandBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{StaticResource Dyc.BrandStartColor}" Offset="0" />
        <GradientStop Color="{StaticResource Dyc.BrandEndColor}" Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="Dyc.OnBrandBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="Dyc.OnBrandSubtleBrush" Color="#DDFFFFFF" />
    <SolidColorBrush x:Key="Dyc.LogoChipBrush" Color="#FF000000" />
    <SolidColorBrush x:Key="Dyc.BrandButtonBrush" Color="#29FFFFFF" />
    <SolidColorBrush x:Key="Dyc.BrandButtonHoverBrush" Color="#47FFFFFF" />

    <views:NodeBodyTemplateSelector x:Key="Dyc.NodeBodySelector" />
    <views:ColorChannelsToBrushConverter x:Key="Dyc.ColorChannelsToBrush" />
    <views:AutoSizeLimitConverter x:Key="Dyc.AutoSizeLimit" />
    <BooleanToVisibilityConverter x:Key="Dyc.BoolToVisibility" />

